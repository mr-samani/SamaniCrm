{
  "name": "samani-crm",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve -o --port=5753 --ssl --hmr",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "generate-api": "set JAVA_OPTS=-Djavax.net.ssl.trustStoreType=Windows-ROOT -Dlog.level=error&& openapi-generator-cli generate -g typescript-angular -o src/shared/service-proxies -c open-api-config.json --skip-validate-spec",
    "apiGen": "node ./scripts/check-api-and-generate.js",
    "format": "prettier --write \".//src//app//**//*.{ts,html,css,scss}\"",
    "*ngTo@": "ng g @angular/core:control-flow",
    "update-all": "npx npm-check-updates -u -d"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.5",
    "@angular/cdk": "^21.1.5",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/elements": "^21.1.5",
    "@angular/forms": "^21.1.0",
    "@angular/material": "^21.1.5",
    "@angular/material-luxon-adapter": "^21.1.5",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-browser-dynamic": "^21.1.5",
    "@angular/router": "^21.1.0",
    "@microsoft/signalr": "^8.0.7",
    "@mr-samani/event-bus": "^1.0.2",
    "@ngx-translate/core": "^16.0.4",
    "@ngx-translate/http-loader": "^16.0.1",
    "@tinymce/tinymce-angular": "^8.0.1",
    "@zumer/snapdom": "^2.0.2",
    "bootstrap": "^5.3.5",
    "grapesjs": "^0.22.7",
    "grapesjs-blocks-basic": "^1.0.2",
    "grapesjs-blocks-flexbox": "^1.0.1",
    "grapesjs-component-countdown": "^1.0.2",
    "grapesjs-plugin-forms": "^2.0.6",
    "grapesjs-preset-webpage": "^1.0.3",
    "grapesjs-style-bg": "^2.0.2",
    "grapesjs-tooltip": "^0.1.8",
    "grapesjs-tui-image-editor": "^1.0.2",
    "grapesjs-typed": "^2.0.1",
    "lodash-es": "^4.17.21",
    "luxon": "^3.7.2",
    "ngx-alert-modal": "^2.1.0",
    "ngx-drag-drop-kit": "^5.2.2",
    "ngx-image-cropper": "^9.1.5",
    "ngx-input-color": "^4.0.1",
    "ngx-page-builder": "^2.1.1",
    "rxjs": "~7.8.0",    
    "sanitize-html": "^2.14.0",
    "save-dev": "^0.0.1-security",
    "swiper": "^12.1.0",
    "tinymce": "^7.9.1",
    "tslib": "^2.3.0",
    "tus-js-client": "^4.3.1"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "@openapitools/openapi-generator-cli": "^2.21.3",
    "@types/lodash-es": "^4.17.12",
    "@types/luxon": "^3.6.2",    
    "@types/sanitize-html": "^2.13.0",
    "jsdom": "^27.1.0",
    "prettier": "^3.5.3",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
